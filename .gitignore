# Archivogitignore más complejo que antes





# Ignorar archivos de sistema
.DS_Store
Thumbs.db
ehthumbs.db

# Ignorar logs y bases de datos temporales
*.log
*.sqlite
*.sqlite3
*.tmp

# Ignorar módulos de node

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignorar archivos de configuración local
*.env
config/local_*.yml
secrets/*.json

# Ignorar directorios de build
dist/
build/
out/

# Ignorar archivos de IDEs
.idea/
.vscode/
*.iml

# Ignorar todo en /docs excepto README.md
docs/*
!docs/README.md

